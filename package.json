{
  "name": "astra-compute",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "core-engine",
    "frontend"
  ],
  "scripts": {
    "dev": "npm run build:core && npm-run-all --parallel dev:backend dev:frontend",
    "dev:backend": "npm --workspace backend run dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "build": "npm run build:core && npm run build:backend && npm run build:frontend",
    "build:core": "npm --workspace core-engine run build",
    "build:backend": "npm --workspace backend run build",
    "build:frontend": "npm --workspace frontend run build",
    "start": "node server.js",
    "test": "npm run build:core && npm run test:core && npm run test:backend",
    "test:core": "npm --workspace core-engine run test",
    "test:backend": "npm --workspace backend run test"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
